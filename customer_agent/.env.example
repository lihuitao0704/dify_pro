# 客服Agent 环境变量配置
# 复制为 .env 后修改

# 服务端口
CUSTOMER_AGENT_PORT=9000
CUSTOMER_AGENT_HOST=0.0.0.0

# 知识库路径
KNOWLEDGE_PATH=C:/Users/Administrator/PycharmProjects/PythonProject/dify_pro/Knowledge

# LLM（LongCat-2.0）
LONGCAT_API_KEY=your-longcat-api-key
LONGCAT_BASE_URL=https://api.longcat.chat/openai
LONGCAT_MODEL=LongCat-2.0
LLM_TIMEOUT=8

# 桥接服务
STUDY_ABROAD_URL=http://127.0.0.1:5000
EVENT_LECTURE_URL=http://127.0.0.1:8011
BRIDGE_TIMEOUT=5
